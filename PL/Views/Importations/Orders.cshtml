@model List<ML.Importation.ora_imp_corden>

@{
    ViewData["Title"] = "Orders";
}

<div class="container-fluid mt-1 px-2">
    <h2 class="mb-4 text-primary fw-bold">Órdenes posibles a dividir</h2>

    @if (Model != null && Model.Count > 0)
    {
        <div class="table-responsive shadow-sm rounded-3 bg-white p-3">
            <table id="ordersTable" class="table table-hover table-striped table-bordered align-middle mb-0 w-100">
                <thead class="table-dark">
                    <tr>
                        <th>Fecha</th>
                        <th>Folio GTM</th>
                        <th>Orden</th>
                        <th>Piezas</th>
                        <th class="text-center">Editar</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td>@order.fecha</td>
                            <td>@order.fol_gtm</td>
                            <td>@order.oc_madre</td>
                            <td>@order.total_piezas</td>
                            <td class="text-center">
                                <a class="btn btn-warning btn-sm px-3"
                                   asp-controller="Importations"
                                   asp-action="GetDerivedOrders"
                                   asp-route-order="@order.oc_madre"
                                   asp-route-fol_gtm="@order.fol_gtm"
                                   asp-route-total_piezas="@order.total_piezas"
                                   title="Dividir orden">
                                    <i class="bi bi-file-plus"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-danger mt-4" role="alert">
            No hay órdenes pendientes.
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#ordersTable').DataTable({
                pageLength: 10,
                lengthMenu: [10, 20, 50, 100],
                lengthChange: true,
                ordering: true,
                searching: true,
                info: true,
                responsive: true,
                language: {
                    search: "Buscar:",
                    info: "Mostrando _START_ a _END_ de _TOTAL_ registros",
                    infoEmpty: "No hay registros disponibles",
                    emptyTable: "No hay datos para mostrar",
                    paginate: {
                        first: "Primero",
                        last: "Último",
                        next: "Siguiente",
                        previous: "Anterior"
                    }
                },
                columnDefs: [
                    { orderable: false, targets: 3 }
                ]
            });
        });
    </script>
}
