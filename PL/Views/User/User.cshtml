@{
    ViewData["Title"] = "Usuarios";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-1 px-2">
    <h2 class="mb-4 text-primary fw-bold">Administración de usuarios</h2>
    <hr />

    <div class="d-flex justify-content-end mb-3">
        <button class="btn btn-success" onclick="abrirModalAlta()">
            <i class="bi bi-person-plus"></i> Nuevo usuario
        </button>
    </div>

    <div class="table-responsive shadow-sm rounded-3 bg-white p-3">
        <table id="tablaUsuarios" class="table table-hover table-striped table-bordered align-middle mb-0 w-100">
            <thead class="table-dark">
                <tr>
                    <th>Usuario</th>
                    <th>Nombre</th>
                    <th>Almacenes</th>
                    <th>Rol</th>
                    <th class="text-center">Editar</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- Modal Alta -->
<div class="modal fade" id="modalAlta" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Alta de usuario</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input type="text" id="txtUsuId" class="form-control mb-3" placeholder="Usuario">

                <button class="btn btn-primary w-100 mb-3" onclick="buscarUsuario()">Buscar</button>

                <div id="infoUsuario" class="d-none">
                    <p><strong>Nombre:</strong> <span id="lblNombre"></span></p>

                    <select id="selectRolAlta" class="form-select mb-3"></select>

                    <label class="fw-semibold">Almacenes</label>
                    <select id="selectAlmacenesAlta" class="form-select mb-3" multiple size="5"></select>

                    <button class="btn btn-success w-100" onclick="guardarUsuario()">Guardar</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Editar -->
<div class="modal fade" id="modalEditar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Editar rol</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p><strong>Usuario:</strong> <span id="editUsuId"></span></p>
                <p><strong>Nombre:</strong> <span id="editNombre"></span></p>

                <select id="selectRolEdit" class="form-select mb-3"></select>

                <button class="btn btn-warning w-100" onclick="actualizarRol()">Actualizar</button>
            </div>
        </div>
    </div>
</div>

<div id="sendOverlay"
     class="position-fixed top-0 start-0 w-100 h-100 d-none justify-content-center align-items-center"
     style="background: rgba(0,0,0,0.4); z-index:9999;">
    <div class="spinner-border text-primary" style="width:60px;height:60px"></div>
</div>

@section Scripts {
    <script>
        let tablaUsuarios = null
        let usuarioActual = null
        let usuarioEdit = null

        document.addEventListener("DOMContentLoaded", cargarUsuarios)

        function mostrarOverlay() {
            $("#sendOverlay").removeClass("d-none").addClass("d-flex")
        }

        function ocultarOverlay() {
            $("#sendOverlay").addClass("d-none").removeClass("d-flex")
        }

        function cargarUsuarios() {
            mostrarOverlay()

            if (tablaUsuarios) tablaUsuarios.destroy()

            $.get("/User/GetAllUsers", data => {

                let rows = ""

                data.forEach(x => {
                    rows += `
                    <tr>
                        <td>${x.usuId}</td>
                        <td>${x.name}</td>
                        <td>${x.almac}</td>
                        <td>${x.subRol}</td>
                        <td class="text-center">
                            <button class="btn btn-warning btn-sm"
                                onclick='abrirEditar(${JSON.stringify(x)})'>
                                <i class="bi bi-pencil"></i>
                            </button>
                        </td>
                    </tr>`
                })

                $("#tablaUsuarios tbody").html(rows)

                tablaUsuarios = $("#tablaUsuarios").DataTable({
                    pageLength: 10,
                    responsive: true,
                    language: { url: "//cdn.datatables.net/plug-ins/1.13.4/i18n/es-MX.json" }
                })

            }).always(ocultarOverlay)
        }

        function abrirModalAlta() {
            $("#txtUsuId").val("")
            $("#infoUsuario").addClass("d-none")

            new bootstrap.Modal(document.getElementById("modalAlta")).show()
        }

        function buscarUsuario() {
            const usuId = $("#txtUsuId").val().trim()

            if (!usuId) return Swal.fire("Atención", "Ingresa usuario", "warning")

            mostrarOverlay()

            $.ajax({
                url: "/User/GetLgaUsu",
                type: "GET",
                data: { usu_id: usuId },
                success: data => {
                    usuarioActual = data

                    $("#lblNombre").text(data.name)
                    $("#infoUsuario").removeClass("d-none")

                    cargarRoles("#selectRolAlta")
                    cargarAlmacenes()
                },
                error: xhr => Swal.fire("Error", xhr.responseText, "error"),
                complete: ocultarOverlay
            })
        }

        function cargarAlmacenes() {
            $.get("/User/GetAlma", data => {

                let options = ""

                data.forEach(a => {
                    options += `<option value="${a}">${a}</option>`
                })

                $("#selectAlmacenesAlta").html(options)
            })
        }

        function guardarUsuario() {
            const rol = $("#selectRolAlta").val()
            const almacenes = $("#selectAlmacenesAlta").val() || []

            if (!rol || almacenes.length === 0)
                return Swal.fire("Atención", "Selecciona rol y almacenes", "warning")

            mostrarOverlay()

            $.ajax({
                url: "/User/AddUser",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify({
                    usuId: usuarioActual.usuId,
                    subRol: rol,
                    almac: almacenes.join(",")
                }),
                success: () => {
                    bootstrap.Modal.getInstance(document.getElementById("modalAlta")).hide()

                    cargarUsuarios()

                    Swal.fire({
                        icon: "success",
                        title: "Usuario agregado",
                        timer: 1500,
                        showConfirmButton: false
                    })
                },
                error: xhr => Swal.fire("Error", xhr.responseText, "error"),
                complete: ocultarOverlay
            })
        }

        function abrirEditar(user) {
            usuarioEdit = user

            $("#editUsuId").text(user.usuId)
            $("#editNombre").text(user.name)

            cargarRoles("#selectRolEdit", user.subRol)

            new bootstrap.Modal(document.getElementById("modalEditar")).show()
        }

        function actualizarRol() {
            const rol = $("#selectRolEdit").val()

            mostrarOverlay()

            $.ajax({
                url: "/User/UpdateUserRol",
                type: "PATCH",
                contentType: "application/json",
                data: JSON.stringify({
                    usuId: usuarioEdit.usuId,
                    subRol: rol
                }),
                success: () => {
                    bootstrap.Modal.getInstance(document.getElementById("modalEditar")).hide()

                    cargarUsuarios()

                    Swal.fire({
                        icon: "success",
                        title: "Rol actualizado",
                        timer: 1500,
                        showConfirmButton: false
                    })
                },
                error: xhr => Swal.fire("Error", xhr.responseText, "error"),
                complete: ocultarOverlay
            })
        }

        function cargarRoles(selectId, selected = null) {
            $.get("/User/GetRoles", { usu_rol: "USER" }, data => {

                let options = ""

                data.forEach(x => {
                    const sel = selected === x.subRol ? "selected" : ""
                    options += `<option value="${x.subRol}" ${sel}>${x.desRol}</option>`
                })

                $(selectId).html(options)
            })
        }
    </script>
}