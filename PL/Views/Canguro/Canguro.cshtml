@{
    ViewData["Title"] = "Canguro";
}

<div class="container-fluid mt-1 px-2">
    <h2 class="mb-4 text-primary fw-bold">Ordenes canguro</h2>

    <div id="messageContainer"></div>

    <div class="table-responsive shadow-sm rounded-3 bg-white p-3">
        <table id="workTable" class="table table-hover table-striped table-bordered align-middle mb-0 w-100">
            <thead class="table-dark">
                <tr>
                    <th>Tienda</th>
                    <th>SCN</th>
                    <th>Transfer</th>
                    <th>Última Fecha</th>
                    <th>Estatus</th>
                    <th class="text-center">Acción</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- Modal de Mantenimiento -->
<div class="modal fade" id="maintenanceModal" tabindex="-1" aria-labelledby="maintenanceModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="maintenanceModalLabel">Mantenimiento de Entrega</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <form id="maintenanceForm">
                <div class="modal-body">
                    <!-- Campos ocultos -->
                    <input type="hidden" id="hdnTienda" name="Tienda" />
                    <input type="hidden" id="hdnScn" name="Scn" />
                    <input type="hidden" id="hdnTransfer" name="Transfer" />
                    <input type="hidden" id="hdnAlmacen" name="Almacen" />

                    <input type="hidden" id="hdnCodigoCliente" name="CodigoCliente" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="fechaEntrega" class="form-label">Fecha de Entrega</label>
                            <input type="date" class="form-control" id="fechaEntrega" name="FechaEntrega" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="nombreCliente" class="form-label">Nombre Cliente</label>
                            <input type="text" class="form-control" id="nombreCliente" readonly disabled />
                        </div>
                    </div>

                    <!-- Datos de contacto -->
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label for="telefono0" class="form-label">Teléfono 1</label>
                            <input type="text" class="form-control" id="telefono0" readonly disabled />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="telefono1" class="form-label">Teléfono 2</label>
                            <input type="text" class="form-control" id="telefono1" readonly disabled />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="telefono2" class="form-label">Teléfono 3</label>
                            <input type="text" class="form-control" id="telefono2" readonly disabled />
                        </div>
                    </div>

                    <!-- Dirección -->
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label for="codigoPostal" class="form-label">Código Postal</label>
                            <input type="text" class="form-control" id="codigoPostal" name="CodigoPostal" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="estado" class="form-label">Estado</label>
                            <input type="text" class="form-control" id="estado" name="Estado" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="codigoEstado" class="form-label">Código Estado</label>
                            <input type="text" class="form-control" id="codigoEstado" name="CodigoEstado" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="municipio" class="form-label">Municipio</label>
                            <input type="text" class="form-control" id="municipio" name="Municipio" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="colonia" class="form-label">Colonia</label>
                            <input type="text" class="form-control" id="colonia" name="Colonia" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-5 mb-3">
                            <label for="calle" class="form-label">Calle</label>
                            <input type="text" class="form-control" id="calle" name="Calle" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label for="numExt" class="form-label">Número Exterior</label>
                            <input type="text" class="form-control" id="numExt" name="NumExt" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="numInt" class="form-label">Número Interior</label>
                            <input type="text" class="form-control" id="numInt" name="NumInt" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="observaciones" class="form-label">Observaciones</label>
                            <textarea class="form-control" id="observaciones" name="Observaciones" rows="2"></textarea>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="referencias" class="form-label">Referencias</label>
                            <textarea class="form-control" id="referencias" name="Referencias" rows="2"></textarea>
                        </div>
                    </div>

                    <!-- Toogles -->
                    <div class="row mb-3">
                        <div class="col-md-12">
                            <div class="d-flex gap-4 flex-wrap">
                                <label class="switch-label">
                                    <input type="checkbox" id="switchPanel" class="switch-input toggle-sn" />
                                    <span class="switch-slider"></span>
                                    <span class="switch-text">Panel</span>
                                </label>
                                <label class="switch-label">
                                    <input type="checkbox" id="switchMasGente" class="switch-input toggle-sn" />
                                    <span class="switch-slider"></span>
                                    <span class="switch-text">MasGente</span>
                                </label>
                                <label class="switch-label">
                                    <input type="checkbox" id="switchVolado" class="switch-input toggle-sn" />
                                    <span class="switch-slider"></span>
                                    <span class="switch-text">Volado</span>
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- Coordenadas -->
                    <div class="row">
                        <div class="col-md-5 mb-3">
                            <label for="longitud" class="form-label">Longitud</label>
                            <input type="text" class="form-control" id="longitud" name="Longitud" />
                        </div>
                        <div class="col-md-5 mb-3">
                            <label for="latitud" class="form-label">Latitud</label>
                            <input type="text" class="form-control" id="latitud" name="Latitud" />
                        </div>
                        <div class="col-md-2 mb-3 d-flex align-items-end">
                            <button type="button" id="btnRecalcular" class="btn btn-outline-secondary w-100">Recalcular</button>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Guardar Cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal para Marcar Evento (Estatus 3) -->
<div class="modal fade" id="eventModal" tabindex="-1" aria-labelledby="eventModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title" id="eventModalLabel">Marcar Evento de Entrega</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <p>¿La orden fue entregada correctamente?</p>
                <input type="hidden" id="eventScn" />
                <input type="hidden" id="eventTienda" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger" id="btnEventNo">No entregado</button>
                <button type="button" class="btn btn-success" id="btnEventSi">Sí, entregado</button>
            </div>
        </div>
    </div>
</div>

<!-- Loading Overlay -->
<div id="loadingOverlay">
    <div class="spinner-custom"></div>
</div>

@section Styles {
    <style>
        #loadingOverlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 9999;
            justify-content: center;
            align-items: center;
        }

        .spinner-custom {
            width: 60px;
            height: 60px;
            border: 8px solid #eee;
            border-top: 8px solid #3498db;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @@keyframes spin {
            0% {
                transform: rotate(0deg);
            }

            100% {
                transform: rotate(360deg);
            }
        }

        .switch-label {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
        }

        .switch-input {
            position: absolute;
            opacity: 0;
            width: 0;
            height: 0;
        }

        .switch-slider {
            position: relative;
            display: inline-block;
            width: 50px;
            height: 26px;
            background-color: #ccc;
            border-radius: 34px;
            transition: background-color 0.3s ease;
        }

            .switch-slider::before {
                content: "";
                position: absolute;
                height: 20px;
                width: 20px;
                left: 3px;
                bottom: 3px;
                background-color: white;
                border-radius: 50%;
                transition: transform 0.3s ease;
            }

        .switch-input:checked + .switch-slider {
            background-color: #dc3545;
        }

            .switch-input:checked + .switch-slider::before {
                transform: translateX(24px);
            }

            .switch-input:checked + .switch-slider + .switch-text {
                color: #dc3545;
                font-weight: 600;
            }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let currentRowData = null; // Para almacenar datos del renglón seleccionado

        $(document).ready(function () {
            loadWorkList();
        });

        function showLoader() {
            $('#loadingOverlay').css('display', 'flex');
        }

        function hideLoader() {
            $('#loadingOverlay').hide();
        }

        function loadWorkList() {
            showLoader();

            if ($.fn.DataTable.isDataTable('#workTable')) {
                $('#workTable').DataTable().clear().destroy();
                $('#workTable tbody').empty();
            }

            $.ajax({
                url: '@Url.Action("GetWorkList", "Canguro")',
                type: 'GET',
                dataType: 'json',
                success: function (response) {
                    // Mostrar mensaje opcional
                    if (response.message) {
                        $('#messageContainer').html(`
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                ${response.message}
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        `);
                    }

                    $('#workTable').DataTable({
                        data: response.data,
                        columns: [
                            { data: 'tienda', defaultContent: '' },
                            { data: 'scn', defaultContent: '' },
                            { data: 'transfer', defaultContent: '' },
                            { data: 'ultFecha', defaultContent: '' },
                            { data: 'estatus', defaultContent: '' },
                            {
                                data: null,
                                className: 'text-center',
                                orderable: false,
                                searchable: false,
                                render: function (data, type, row) {
                                    const idEstatus = row.idEstatus;
                                    let buttonHtml = '';

                                    if (idEstatus === 'X') {
                                        buttonHtml = `<button class="btn btn-warning btn-sm btn-habilitar" data-tienda="${row.tienda}" data-scn="${row.scn}">Habilitar</button>`;
                                    } else if (idEstatus === '0') {
                                        buttonHtml = `<button class="btn btn-primary btn-sm btn-mantenimiento" data-tienda="${row.tienda}" data-scn="${row.scn}">Mantenimiento</button>`;
                                    } else if (idEstatus === '3') {
                                        buttonHtml = `<button class="btn btn-info btn-sm btn-evento" data-tienda="${row.tienda}" data-scn="${row.scn}">Marcar Evento</button>`;
                                    } else {
                                        buttonHtml = `<button class="btn btn-secondary btn-sm" disabled>Sin acción</button>`;
                                    }
                                    return buttonHtml;
                                }
                            }
                        ],
                        pageLength: 10,
                        lengthMenu: [10, 20, 50, 100],
                        language: {
                            search: "Buscar:",
                            info: "Mostrando _START_ a _END_ de _TOTAL_ registros",
                            infoEmpty: "No hay registros disponibles",
                            emptyTable: "No hay datos para mostrar",
                            zeroRecords: "No se encontraron registros",
                            paginate: {
                                first: "Primero",
                                last: "Último",
                                next: "Siguiente",
                                previous: "Anterior"
                            }
                        }
                    });
                },
                error: function (xhr) {
                    if (xhr.status === 401) {
                        window.location.href = '/Login/Login';
                        return;
                    }
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: xhr.responseText || 'Error al cargar los datos'
                    });
                },
                complete: function () {
                    hideLoader();
                }
            });
        }

        // Habilitar (Estado X)
        $(document).on('click', '.btn-habilitar', function () {
            const row = $(this).closest('tr');
            const table = $('#workTable').DataTable();
            const rowData = table.row(row).data();

            if (!rowData) {
                Swal.fire('Error', 'No se pudo obtener la información de la fila', 'error');
                return;
            }

            // Crear objeto CanguroInfo completo
            const canguroInfo = {
                Almacen: rowData.almacen || '',
                Tienda: rowData.tienda || '',
                Scn: rowData.scn || '',
                Transfer: rowData.transfer || '',
                UltFecha: rowData.ultFecha || '',
                IdEstatus: rowData.idEstatus || '',
                Estatus: rowData.estatus || ''
            };

            Swal.fire({
                title: '¿Habilitar registro?',
                text: `Se habilitará el SCN ${canguroInfo.Scn} de la tienda ${canguroInfo.Tienda}`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Sí, habilitar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    showLoader();
                    $.ajax({
                        url: '@Url.Action("AcceptCanguro", "Canguro")',
                        type: 'POST',
                        contentType: 'application/json',
                        data: JSON.stringify(canguroInfo),
                        success: function (response) {
                            if (response.correct) {
                                Swal.fire('Habilitado', response.message, 'success');
                                loadWorkList(); // Refrescar tabla
                            } else {
                                Swal.fire('Error', response.message, 'error');
                            }
                        },
                        error: function () {
                            Swal.fire('Error', 'Ocurrió un error al habilitar', 'error');
                        },
                        complete: function () {
                            hideLoader();
                        }
                    });
                }
            });
        });

        // Mantenimiento (Estado 0) - abre modal
        $(document).on('click', '.btn-mantenimiento', function () {
            // Obtener la fila completa desde DataTable
            const row = $(this).closest('tr');
            const table = $('#workTable').DataTable();
            const rowData = table.row(row).data();

            if (!rowData) {
                Swal.fire('Error', 'No se pudo obtener la información de la fila', 'error');
                return;
            }

            // Guardar datos completos para uso posterior
            currentRowData = rowData;

            // Crear objeto CanguroInfo completo
            const canguroInfo = {
                Almacen: rowData.almacen || '',
                Tienda: rowData.tienda || '',
                Scn: rowData.scn || '',
                Transfer: rowData.transfer || '',
                UltFecha: rowData.ultFecha || '',
                IdEstatus: rowData.idEstatus || '',
                Estatus: rowData.estatus || ''
            };

            showLoader();
            $.ajax({
                url: '@Url.Action("GetCanguroInfo", "Canguro")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(canguroInfo),
                success: function (response) {
                    if (response.correct && response.data) {
                        const header = response.data;
                        // Llenar campos del modal
                        $('#hdnAlmacen').val(canguroInfo.Almacen);
                        $('#hdnTienda').val(canguroInfo.Tienda);
                        $('#hdnScn').val(canguroInfo.Scn);
                        $('#hdnTransfer').val(header.transfer || canguroInfo.Transfer || '');
                        $('#fechaEntrega').val(header.fechaEntrega ? formatDateForInput(header.fechaEntrega) : '');
                        $('#nombreCliente').val(header.nombreCliente || '');
                        $('#hdnCodigoCliente').val(header.codigoCliente || '');
                        $('#telefono0').val(header.telefono0 || '');
                        $('#telefono1').val(header.telefono1 || '');
                        $('#telefono2').val(header.telefono2 || '');
                        $('#codigoPostal').val(header.codigoPostal || '');
                        $('#estado').val(header.estado || '');
                        $('#codigoEstado').val(header.codigoEstado || '');
                        $('#municipio').val(header.municipio || '');
                        $('#colonia').val(header.colonia || '');
                        $('#calle').val(header.calle || '');
                        $('#numExt').val(header.numExt || '');
                        $('#numInt').val(header.numInt || '');
                        $('#observaciones').val(header.observaciones || '');
                        $('#referencias').val(header.referencias || '');
                        $('#longitud').val(header.longitud || '');
                        $('#latitud').val(header.latitud || '');
                        // Switches
                        $('#switchPanel').prop('checked', header.panel === 'S');
                        $('#switchMasGente').prop('checked', header.masGente === 'S');
                        $('#switchVolado').prop('checked', header.volado === 'S');

                        $('#maintenanceModal').modal('show');
                    } else {
                        Swal.fire('Error', response.message || 'No se pudo obtener la información', 'error');
                    }
                },
                error: function (xhr) {
                    console.error(xhr);
                    Swal.fire('Error', 'Error al cargar los datos de mantenimiento', 'error');
                },
                complete: function () {
                    hideLoader();
                }
            });
        });
        // Guardar cambios del modal de mantenimiento
    $('#maintenanceForm').on('submit', function (e) {
            e.preventDefault();

            // Validar coordenadas antes de enviar
            const latitud = $('#latitud').val();
            const longitud = $('#longitud').val();

            const coordValidation = validateCoordinates(latitud, longitud);

            if (!coordValidation.valid) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Coordenadas inválidas',
                    text: coordValidation.message,
                    confirmButtonColor: '#dc3545'
                });
                return; // Detener el envío
            }

            // Construir objeto Header con la nomenclatura correcta
            const header = {
                Facility: '',
                OrderRelease: '',
                SCN: $('#hdnScn').val(),
                Transfer: $('#hdnTransfer').val(),
                FechaEntrega: $('#fechaEntrega').val(),
                CodigoCliente: $('#hdnCodigoCliente').val(),
                NombreCliente: $('#nombreCliente').val(),
                Telefono0: $('#telefono0').val(),
                Telefono1: $('#telefono1').val(),
                Telefono2: $('#telefono2').val(),
                Estado: $('#estado').val(),
                CodigoEstado: $('#codigoEstado').val(),
                Municipio: $('#municipio').val(),
                Colonia: $('#colonia').val(),
                CodigoPostal: $('#codigoPostal').val(),
                Calle: $('#calle').val(),
                NumExt: $('#numExt').val(),
                NumInt: $('#numInt').val(),
                Observaciones: $('#observaciones').val(),
                Referencias: $('#referencias').val(),
                Panel: $('#switchPanel').is(':checked') ? 'S' : 'N',
                MasGente: $('#switchMasGente').is(':checked') ? 'S' : 'N',
                Volado: $('#switchVolado').is(':checked') ? 'S' : 'N',
                Longitud: $('#longitud').val(),
                Latitud: $('#latitud').val()
            };

            // Construir objeto CanguroInfo con la nomenclatura correcta (mayúsculas)
            const canguro = {
                Almacen: $('#hdnAlmacen').val(), 
                Tienda: $('#hdnTienda').val(),
                Scn: $('#hdnScn').val(),
                Transfer: $('#hdnTransfer').val(),
                UltFecha: '',  
                IdEstatus: '',
                Estatus: ''
            };

            showLoader();
            $.ajax({
                url: '@Url.Action("Maintenance", "Canguro")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    canguro: canguro,  // <- Esto se mapea a Canguro en la clase Maintenance
                    header: header     // <- Esto se mapea a Header en la clase Maintenance
                }),
                success: function (response) {
                    if (response.correct) {
                        Swal.fire('Guardado', response.message, 'success');
                        $('#maintenanceModal').modal('hide');
                        loadWorkList();
                    } else {
                        Swal.fire('Error', response.message, 'error');
                    }
                },
                error: function () {
                    Swal.fire('Error', 'No se pudo guardar los cambios', 'error');
                },
                complete: function () {
                    hideLoader();
                }
            });
        });

        // Marcar Evento (Estado 3)
        $(document).on('click', '.btn-evento', function () {
            const tienda = $(this).data('tienda');
            const scn = $(this).data('scn');
            $('#eventScn').val(scn);
            $('#eventTienda').val(tienda);
            $('#eventModal').modal('show');
        });

        $('#btnEventSi').on('click', function () {
            const scn = $('#eventScn').val();
            const tienda = $('#eventTienda').val();
            confirmarEvento(scn, tienda, true);
        });

        $('#btnEventNo').on('click', function () {
            const scn = $('#eventScn').val();
            const tienda = $('#eventTienda').val();
            confirmarEvento(scn, tienda, false);
        });

                // Para Marcar Evento (Estado 3) - usando la fila actual
        function confirmarEvento(scn, tienda, entregado) {
            // Usar currentRowData que ya guardaste
            if (!currentRowData) {
                Swal.fire('Error', 'No se pudo obtener la información de la fila', 'error');
                return;
            }

            // Construir objeto CanguroInfo con los mismos datos que ya usaste en mantenimiento
            const canguroInfo = {
                Almacen: currentRowData.almacen || '',
                Tienda: currentRowData.tienda || '',
                Scn: currentRowData.scn || '',
                Transfer: currentRowData.transfer || '',
                UltFecha: currentRowData.ultFecha || '',
                IdEstatus: currentRowData.idEstatus || '',
                Estatus: currentRowData.estatus || ''
            };

            const deliveredData = {
                isDelivered: entregado,
                canguroInfo: canguroInfo
            };

            showLoader();
            $.ajax({
                url: '@Url.Action("Delivered", "Canguro")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(deliveredData),
                success: function (response) {
                    if (response.correct) {
                        Swal.fire('Evento registrado', response.message, 'success');
                        $('#eventModal').modal('hide');
                        loadWorkList(); // Refrescar tabla
                    } else {
                        Swal.fire('Error', response.message, 'error');
                    }
                },
                error: function () {
                    Swal.fire('Error', 'No se pudo registrar el evento', 'error');
                },
                complete: function () {
                    hideLoader();
                }
            });
        }


        // Recalcular coordenadas con Nominatim (OpenStreetMap)
        $('#btnRecalcular').on('click', async function () {
            const calle = $('#calle').val().trim();
            const colonia = $('#colonia').val().trim();
            const municipio = $('#municipio').val().trim();
            const estado = $('#estado').val().trim();
            const cp = $('#codigoPostal').val().trim();

            if (!calle || !colonia || !municipio || !estado || !cp) {
                Swal.fire('Datos incompletos', 'Completa todos los campos de dirección', 'warning');
                return;
            }

            $(this).prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Buscando...');

            const coords = await getCoordinates(calle, colonia, municipio, estado, cp);

            if (coords) {
                $('#latitud').val(coords.lat);
                $('#longitud').val(coords.lon);
                Swal.fire('Coordenadas actualizadas', `Lat: ${coords.lat}, Lng: ${coords.lon}`, 'success');
            } else {
                Swal.fire('Sin resultados', 'No se encontraron coordenadas para la dirección. Intenta con más detalles.', 'warning');
                $('#latitud').val('');
                $('#longitud').val('');
            }

            $(this).prop('disabled', false).text('Recalcular');
        });

        async function getCoordinates(calle, colonia, municipio, estado, cp) {
            const parts = [calle, colonia, municipio, estado, cp].filter(p => p && p.trim() !== '');
            let address = parts.join(', ');
            let url = `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(address)}&countrycodes=mx&limit=1`;

            try {
                const response = await fetch(url);
                const data = await response.json();
                if (data && data.length > 0) {
                    return { lat: data[0].lat, lon: data[0].lon };
                }
                // Si falla, intentamos sin el número de calle (separar calle del número)
                const calleSinNumero = calle.replace(/[0-9]+$/, '').trim();
                if (calleSinNumero !== calle) {
                    const parts2 = [calleSinNumero, colonia, municipio, estado, cp].filter(p => p && p.trim() !== '');
                    address = parts2.join(', ');
                    url = `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(address)}&countrycodes=mx&limit=1`;
                    const response2 = await fetch(url);
                    const data2 = await response2.json();
                    if (data2 && data2.length > 0) {
                        return { lat: data2[0].lat, lon: data2[0].lon };
                    }
                }
                return null;
            } catch (error) {
                console.error(error);
                return null;
            }
        }

        // Función para validar coordenadas
        function validateCoordinates(lat, lng) {
            // Convertir a número por si vienen como string
            const latitude = parseFloat(lat);
            const longitude = parseFloat(lng);

            // Validar que sean números válidos
            if (isNaN(latitude) || isNaN(longitude)) {
                return {
                    valid: false,
                    message: 'Las coordenadas no son válidas. Deben ser números.'
                };
            }

            // Validar que no sean 0,0
            if (latitude === 0 && longitude === 0) {
                return {
                    valid: false,
                    message: 'Las coordenadas no pueden ser (0, 0). Por favor, recalcula la ubicación.'
                };
            }

            // Validar rangos aproximados (latitud: -90 a 90, longitud: -180 a 180)
            if (latitude < -90 || latitude > 90) {
                return {
                    valid: false,
                    message: `La latitud ${latitude} está fuera del rango válido (-90 a 90).`
                };
            }

            if (longitude < -180 || longitude > 180) {
                return {
                    valid: false,
                    message: `La longitud ${longitude} está fuera del rango válido (-180 a 180).`
                };
            }

            return { valid: true, message: '' };
        }

        // Helper para formatear fecha (dd/MM/yyyy -> yyyy-MM-dd)
        function formatDateForInput(dateStr) {
            if (!dateStr) return '';
            const parts = dateStr.split('/');
            if (parts.length === 3) {
                return `${parts[2]}-${parts[1]}-${parts[0]}`;
            }
            return dateStr;
        }
    </script>
}